# Opcional para la API HTTP: si no está, el cliente debe enviar Authorization: Bearer <token>.
# Recomendado para jobs (ingesta diaria) y Docker si no usás solo el flujo web.
META_ACCESS_TOKEN=

# Opcionales (tienen defaults)
DUCKDB_PATH=/data/analytics.duckdb
META_GRAPH_VERSION=v25.0
API_HOST=0.0.0.0
API_PORT=8000

# CORS: orígenes del frontend (navegador), separados por coma. En Render, añade tu URL https://tu-frontend.onrender.com
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://oderbiz-frontend-v2.onrender.com
